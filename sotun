  # sotun forward add <spec> <user@host> <ssh-port>
  # spec: <port> or <laddr>:<lport>:<raddr>:<rport>
  need_root
  local spec="$1"
  local userhost="$2"
  local ssh_port="$3"

  parse_spec "$spec"
  require_ssh_port "$ssh_port"

