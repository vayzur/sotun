    # shellcheck source=/dev/null
    . "$f"
    local state
    state="$(systemctl is-active "forward@${port}.service" 2>/dev/null || echo inactive)"
    printf "  -L %-35s  %s@%s:%s  [%s]\n" \
      "${FORWARD_LADDR}:${FORWARD_LPORT}:${FORWARD_RADDR}:${FORWARD_RPORT}" \
      "$FORWARD_USER" "$FORWARD_HOST" "$FORWARD_SSH_PORT" "$state"
    found=1
  done < <(find "$FORWARD_CONF_DIR" -maxdepth 1 -type f -print0 2>/dev/null | sort -z)
