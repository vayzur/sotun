  cat > "$FORWARD_CONF_DIR/$SPEC_LPORT" <<EOF
FORWARD_LADDR=$SPEC_LADDR
FORWARD_LPORT=$SPEC_LPORT
FORWARD_RADDR=$SPEC_RADDR
FORWARD_RPORT=$SPEC_RPORT
FORWARD_USER=$user
FORWARD_HOST=$host
FORWARD_SSH_PORT=$ssh_port
EOF

  systemctl enable --now "forward@${SPEC_LPORT}.service"
  info "forward@${SPEC_LPORT} added and started (-L ${SPEC_LADDR}:${SPEC_LPORT}:${SPEC_RADDR}:${SPEC_RPORT} → ${userhost})"
}

