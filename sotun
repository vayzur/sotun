cmd_forward_start()   { need_root; require_listen_port "$1"; systemctl start   "forward@${1}.service"; info "forward@${1} started"; }
cmd_forward_stop()    { need_root; require_listen_port "$1"; systemctl stop    "forward@${1}.service"; info "forward@${1} stopped"; }
cmd_forward_restart() { need_root; require_listen_port "$1"; systemctl restart "forward@${1}.service"; info "forward@${1} restarted"; }

cmd_update() {
  need_root
  local url="https://raw.githubusercontent.com/vayzur/sotun/main/sotun"
  local tmp
  tmp="$(mktemp)"
  info "downloading latest sotun..."
  if ! curl -fsSL "$url" -o "$tmp"; then
    err "failed to download from $url"
    rm -f "$tmp"
    exit 1
  fi
  chmod +x "$tmp"
  install -m 0755 "$tmp" /usr/local/bin/sotun
  rm -f "$tmp"
  info "sotun binary updated"
  write_proxy_template
  write_tunnel_template
  write_forward_template
  info "systemd templates updated"
  info "sotun updated to latest version"
}

cmd_uninstall() {
  need_root
  warn "stopping and removing all proxy, tunnel, and forward services..."

  # stop/disable/remove all proxy instances
  while IFS= read -r -d '' f; do
    local port
    port="$(basename "$f")"
    systemctl stop    "proxy@${port}.service" 2>/dev/null || true
    systemctl disable "proxy@${port}.service" 2>/dev/null || true
  done < <(find "$PROXY_CONF_DIR" -maxdepth 1 -type f -print0 2>/dev/null)

  # stop/disable/remove all tunnel instances
  while IFS= read -r -d '' f; do
    local port
    port="$(basename "$f")"
    systemctl stop    "tunnel@${port}.service" 2>/dev/null || true
    systemctl disable "tunnel@${port}.service" 2>/dev/null || true
  done < <(find "$TUNNEL_CONF_DIR" -maxdepth 1 -type f -print0 2>/dev/null)

  # stop/disable/remove all forward instances
  while IFS= read -r -d '' f; do
    local port
    port="$(basename "$f")"
    systemctl stop    "forward@${port}.service" 2>/dev/null || true
    systemctl disable "forward@${port}.service" 2>/dev/null || true
  done < <(find "$FORWARD_CONF_DIR" -maxdepth 1 -type f -print0 2>/dev/null)

  rm -f "$SYSTEMD_DIR/proxy@.service"
  rm -f "$SYSTEMD_DIR/tunnel@.service"
  rm -f "$SYSTEMD_DIR/forward@.service"
  reload_daemon
  rm -rf "$CONF_DIR"
  rm -f /usr/local/bin/sotun
  info "sotun fully removed"
}

cmd_help() {
  cat <<EOF

sotun v${VERSION} — ssh tunnel manager
https://github.com/vayzur/sotun

usage:
  sotun init                                     prepare this node (generate ssh key)

  sotun proxy add <port> <user@host> <ssh-port>  add a local socks5 proxy via ssh -D
  sotun proxy del <port>                          remove a proxy
  sotun proxy list                                list all proxies
  sotun proxy start   <port>
  sotun proxy stop    <port>
  sotun proxy restart <port>

  sotun tunnel add <spec> <user@host> <ssh-port> push a port to the remote node via ssh -R
  sotun tunnel del <port>                         remove a tunnel
  sotun tunnel list                               list all tunnels
  sotun tunnel start   <port>
  sotun tunnel stop    <port>
  sotun tunnel restart <port>

  sotun forward add <spec> <user@host> <ssh-port> pull a port from the remote node via ssh -L
  sotun forward del <port>                         remove a forward
  sotun forward list                               list all forwards
  sotun forward start   <port>
  sotun forward stop    <port>
  sotun forward restart <port>

  sotun update                                   pull and install latest version
  sotun uninstall                                remove everything sotun installed

spec:
  <port>                      short form — binds 127.0.0.1:<port> on both ends
  <laddr>:<lport>:<raddr>:<rport>   full form — explicit bind and target addresses

port restrictions:
  <port> / <lport> / <rport>: must be 1024-65535
  <ssh-port> (remote sshd):   must be 1-65535

examples:
  sotun proxy add 1080 root@127.0.0.1 22
  sotun tunnel add 1080 root@203.0.113.10 22
  sotun tunnel add 127.0.0.1:1080:0.0.0.0:1080 root@203.0.113.10 22
  sotun forward add 1080 root@203.0.113.10 22
  sotun forward add 127.0.0.1:8080:127.0.0.1:80 root@203.0.113.10 22

EOF
}

cmd="${1:-}"
sub="${2:-}"

case "$cmd" in
  init)       cmd_init ;;

  proxy)
    case "$sub" in
      add)
        [ $# -lt 5 ] && { err "usage: sotun proxy add <port> <user@host> <ssh-port>"; exit 1; }
        cmd_proxy_add "$3" "$4" "$5"
        ;;
      del)
        [ $# -lt 3 ] && { err "usage: sotun proxy del <port>"; exit 1; }
        cmd_proxy_del "$3"
        ;;
      list)     cmd_proxy_list ;;
      start)
        [ $# -lt 3 ] && { err "usage: sotun proxy start <port>"; exit 1; }
        cmd_proxy_start "$3"
        ;;
      stop)
        [ $# -lt 3 ] && { err "usage: sotun proxy stop <port>"; exit 1; }
        cmd_proxy_stop "$3"
        ;;
      restart)
        [ $# -lt 3 ] && { err "usage: sotun proxy restart <port>"; exit 1; }
        cmd_proxy_restart "$3"
        ;;
      *) err "unknown proxy command '$sub'. run 'sotun help'."; exit 1 ;;
    esac
    ;;

  tunnel)
    case "$sub" in
      add)
        [ $# -lt 5 ] && { err "usage: sotun tunnel add <spec> <user@host> <ssh-port>"; exit 1; }
        cmd_tunnel_add "$3" "$4" "$5"
        ;;
      del)
        [ $# -lt 3 ] && { err "usage: sotun tunnel del <port>"; exit 1; }
        cmd_tunnel_del "$3"
        ;;
      list)     cmd_tunnel_list ;;
      start)
        [ $# -lt 3 ] && { err "usage: sotun tunnel start <port>"; exit 1; }
        cmd_tunnel_start "$3"
        ;;
      stop)
        [ $# -lt 3 ] && { err "usage: sotun tunnel stop <port>"; exit 1; }
        cmd_tunnel_stop "$3"
        ;;
      restart)
        [ $# -lt 3 ] && { err "usage: sotun tunnel restart <port>"; exit 1; }
        cmd_tunnel_restart "$3"
        ;;
      *) err "unknown tunnel command '$sub'. run 'sotun help'."; exit 1 ;;
    esac
    ;;

  forward)
    case "$sub" in
      add)
        [ $# -lt 5 ] && { err "usage: sotun forward add <spec> <user@host> <ssh-port>"; exit 1; }
        cmd_forward_add "$3" "$4" "$5"
        ;;
      del)
        [ $# -lt 3 ] && { err "usage: sotun forward del <port>"; exit 1; }
        cmd_forward_del "$3"
        ;;
      list)     cmd_forward_list ;;
      start)
        [ $# -lt 3 ] && { err "usage: sotun forward start <port>"; exit 1; }
        cmd_forward_start "$3"
        ;;
      stop)
        [ $# -lt 3 ] && { err "usage: sotun forward stop <port>"; exit 1; }
        cmd_forward_stop "$3"
        ;;
      restart)
        [ $# -lt 3 ] && { err "usage: sotun forward restart <port>"; exit 1; }
        cmd_forward_restart "$3"
        ;;
      *) err "unknown forward command '$sub'. run 'sotun help'."; exit 1 ;;
    esac
    ;;

  update)     cmd_update ;;
  uninstall)  cmd_uninstall ;;
  help|"")    cmd_help ;;
  *)          err "unknown command '$cmd'. run 'sotun help'."; exit 1 ;;
esac
